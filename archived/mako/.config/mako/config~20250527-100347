# Mako configuration file

# Appearance
font=Noto Sans 11
width=350
height=100
margin=10
padding=15
border-size=2
border-radius=10
background-color=#1e1e2e
text-color=#cdd6f4
border-color=#89b4fa
progress-color=over #89b4fa

# Behavior
default-timeout=5000
ignore-timeout=0
layer=overlay
anchor=top-right

# Enable close button with minimal configuration
actions=1

# Format (use HTML-like markup for rich text)
format=<b>%s</b>\n%b
markup=1

# Icons
icon-path=/usr/share/icons/Papirus-Dark
max-icon-size=64
icon-location=left

# Grouping & Sorting
group-by=app-name
max-visible=5
sort=-time

# Style specific settings for different apps
[urgency=low]
border-color=#313244
default-timeout=2000

[urgency=normal]
border-color=#89b4fa
default-timeout=5000

[urgency=high]
border-color=#f38ba8
text-color=#f38ba8
default-timeout=0

# Application specific settings
[app-name=Spotify]
border-color=#a6e3a1
default-timeout=2000

[app-name=Firefox]
border-color=#fab387
