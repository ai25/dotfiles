#!/bin/bash

get_volume() {
  # Get default sink name
  default_sink=$(pactl get-default-sink)

  # Get volume and mute status for the default sink
  volume_info=$(pactl get-sink-volume "$default_sink")
  mute_info=$(pactl get-sink-mute "$default_sink")

  # Extract volume percentage (first channel only)
  vol=$(echo "$volume_info" | grep -oP '\d+%' | head -1 | tr -d '%')

  # Check mute status
  if [[ "$mute_info" == *"yes" ]]; then
    echo "[\"muted\", \"0\"]"
  else
    echo "[\"unmuted\", \"$vol\"]"
  fi
}

# Initial volume
get_volume

# Monitor for volume changes
pactl subscribe | while read -r line; do
  if [[ $line == *"sink"* ]]; then
    get_volume
  fi
done
