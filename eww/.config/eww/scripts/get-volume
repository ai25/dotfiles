#!/bin/bash

get_volume() {
    # Get default sink name
    sink=$(pactl get-default-sink)
    
    # Get volume and mute status
    volume=$(pactl get-sink-volume "$sink" | grep -oP '\d+(?=%)' | head -n 1)
    mute=$(pactl get-sink-mute "$sink" | awk '{print $2}')
    
    if [[ "$mute" == "yes" ]]; then
        echo "[\"muted\", \"$volume\"]"
    else
        echo "[\"unmuted\", \"$volume\"]"
    fi
}

# Initial volume
get_volume

# Monitor for volume changes
pactl subscribe | while read -r line; do
    if [[ $line == *"sink"* ]]; then
        get_volume
    fi
done
