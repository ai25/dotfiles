#!/bin/bash

get_workspaces() {
  # Get active workspace
  active=$(hyprctl activeworkspace -j | jq '.id')
  active_special=$(hyprctl activewindow -j | jq -r '.workspace.name' | grep -q "special:" && echo "true" || echo "false")

  # Separate arrays for regular and special workspaces
  regular_spaces=()
  special_spaces=()

  # Process all workspaces
  while IFS= read -r workspace; do
    id=$(echo "$workspace" | jq -r '.id')
    name=$(echo "$workspace" | jq -r '.name')

    # Skip empty lines
    [ -z "$id" ] && continue

    # Check if it's a special workspace
    if [[ "$name" == special* ]]; then
      special_num=$((101 + id))
      display_name="S${special_num}"

      if [ "$id" = "$active" ] && [ "$active_special" = "true" ]; then
        special_spaces+=("{\"id\":$id,\"focused\":true,\"special\":true,\"name\":\"$display_name\"}")
      else
        special_spaces+=("{\"id\":$id,\"focused\":false,\"special\":true,\"name\":\"$display_name\"}")
      fi
    else
      if [ "$id" = "$active" ] && [ "$active_special" = "false" ]; then
        regular_spaces+=("{\"id\":$id,\"focused\":true,\"special\":false,\"name\":\"$id\"}")
      else
        regular_spaces+=("{\"id\":$id,\"focused\":false,\"special\":false,\"name\":\"$id\"}")
      fi
    fi
  done < <(hyprctl workspaces -j | jq -c '.[]' | sort -V)

  # Combine arrays with regular workspaces first
  spaces=("${regular_spaces[@]}" "${special_spaces[@]}")

  # Output JSON array
  printf "[%s]\n" "$(
    IFS=,
    echo "${spaces[*]}"
  )"
}

# Initial state
get_workspaces

# Monitor workspace changes
socat -U - "UNIX-CONNECT:$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock" | while read -r line; do
  case ${line%>>*} in
  workspace* | createworkspace* | destroyworkspace* | moveworkspace* | activewindow*)
    get_workspaces
    ;;
  esac
done
