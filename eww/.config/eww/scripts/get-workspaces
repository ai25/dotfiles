#!/bin/bash

get_workspaces() {
    # Get active workspace, ensure it's a positive number
    active=$(hyprctl activeworkspace -j | jq '.id | select(. > 0)')
    if [ -z "$active" ]; then
        active=1
    fi
    
    spaces="["
    first=1
    
    # Get all workspaces and construct JSON
    while IFS= read -r id; do
        # Skip empty lines or negative numbers
        [ -z "$id" ] && continue
        [ "$id" -lt 1 ] && continue
        
        # Add comma if not first item
        if [ $first -eq 0 ]; then
            spaces+=","
        fi
        first=0
        
        # Add the workspace with its focused state
        if [ "$id" = "$active" ]; then
            spaces+="{\"id\":$id,\"focused\":true}"
        else
            spaces+="{\"id\":$id,\"focused\":false}"
        fi
    done < <(hyprctl workspaces -j | jq -r '.[].id' | sort -n)
    
    spaces+="]"
    echo "$spaces"
}

# Initial state
get_workspaces

# Monitor workspace changes
socat -U - UNIX-CONNECT:"$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock" | while read -r line; do
    case ${line%>>*} in
        workspace*|createworkspace*|destroyworkspace*|moveworkspace*)
            get_workspaces
            ;;
    esac
done
