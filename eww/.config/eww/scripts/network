#!/bin/bash

get_bytes() {
    # Find active network interface
    interface=$(ip -o link show | awk -F': ' '$2 !~ /lo/ {print $2}' | while read iface; do
    if ip addr show "$iface" | grep -q "inet "; then
        echo "$iface"
        break
    fi
done)
    
    # If no interface is found, try getting the first non-loopback interface
    if [ -z "$interface" ]; then
        interface=$(ip link show | grep -v "lo:" | grep "state UP" | head -n1 | cut -d: -f2 | tr -d ' ')
    fi
    
    # If still no interface found, show zeros
    if [ -z "$interface" ]; then
        echo "0 0"
        return
    fi
    
    # Read RX and TX bytes for the interface
    read rx < "/sys/class/net/${interface}/statistics/rx_bytes"
    read tx < "/sys/class/net/${interface}/statistics/tx_bytes"
    
    echo "$rx $tx"
}

# Function to calculate speed
calculate_speed() {
    local old_rx=$1
    local old_tx=$2
    local new_rx=$3
    local new_tx=$4
    
    # Calculate bytes transferred during the period
    rx_bytes=$((new_rx - old_rx))
    tx_bytes=$((new_tx - old_tx))
    
    # Format speeds with units
    format_speed() {
        local bytes=$1
        if command -v bc >/dev/null 2>&1; then
          kib=$(echo "scale=1; $bytes/1024" | bc)
          if (( $(echo "$kib > 1024" | bc -l) )); then
              mib=$(echo "scale=1; $kib/1024" | bc)
              [ "${mib:0:1}" = "." ] && mib="0$mib"
              echo "${mib}MB/s"
          else
              [ "${kib:0:1}" = "." ] && kib="0$kib"
              echo "${kib}KB/s"
          fi
        else
            kib=$((bytes / 1024))
            if [ $kib -gt 1024 ]; then
                mib=$((kib / 1024))
                echo "${mib}MB/s"
            else
                echo "${kib}KB/s"
            fi
        fi

    }
    
    # Calculate and format both speeds
    rx_speed=$(format_speed $rx_bytes)
    tx_speed=$(format_speed $tx_bytes)
    
    echo "$rx_speed $tx_speed"
}

# Get initial values
read old_rx old_tx <<< $(get_bytes)

# Wait for one second
sleep 1

# Get new values
read new_rx new_tx <<< $(get_bytes)

# Calculate and output speeds
case $1 in
    "--up")
        # Get upload speed
        read rx_speed tx_speed <<< $(calculate_speed $old_rx $old_tx $new_rx $new_tx)
        echo "$tx_speed"
        ;;
    "--down")
        # Get download speed
        read rx_speed tx_speed <<< $(calculate_speed $old_rx $old_tx $new_rx $new_tx)
        echo "$rx_speed"
        ;;
esac
