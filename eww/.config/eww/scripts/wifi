#!/bin/bash

get_wifi_info() {
    # Get the current wireless device
    device=$(nmcli -t -f DEVICE,TYPE device | grep ":wifi$" | cut -d':' -f1)
    
    if [ -z "$device" ]; then
        echo '{"ssid": "No WiFi", "strength": 0, "ip": ""}'
        return
    fi
    
    # Get connection info for the wireless device
    connection_info=$(nmcli -t -f DEVICE,STATE,CONNECTION device | grep "^$device:" 2>/dev/null)
    
    if [ -z "$connection_info" ] || [[ $connection_info == *"disconnected"* ]]; then
        echo '{"ssid": "Disconnected", "strength": 0, "ip": ""}'
        return
    fi
    
    # Get SSID
    ssid=$(echo "$connection_info" | cut -d':' -f3)
    
    # Get signal strength from device wifi list
    strength=$(nmcli -f IN-USE,SIGNAL device wifi list | grep "^*" | awk '{print $2}')
    
    # If no signal strength is found, default to 0
    if [ -z "$strength" ]; then
        strength=0
    fi
    
    # Get IP address
    ip=$(ip -json addr show dev "$device" | jq -r '.[].addr_info[] | select(.family == "inet") | .local' 2>/dev/null)
    
    # If no IP is found, use empty string
    if [ -z "$ip" ]; then
        ip=""
    fi
    
    echo "{\"ssid\": \"$ssid\", \"strength\": $strength, \"ip\": \"$ip\"}"
}

# Initial state
get_wifi_info

# Monitor changes every 30 seconds
while true; do
    sleep 30
    get_wifi_info
done
