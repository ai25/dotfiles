client.focused #dcdccc #dcdccc #3c3b37 #ffcfaf
client.focused_inactive #3c3b37 #3c3b37 #7f9f7f #3c3b37
client.unfocused #3c3b37 #3c3b37 #dcdccc #3c3b37
client.urgent #dca3a3 #dca3a3 #dcdccc #3c3b37

# gaps
gaps inner 10
gaps outer 10

# Resizing windows
bindsym $super+Shift+h resize shrink width 10 px or 10 ppt
bindsym $super+Shift+j resize grow height 10 px or 10 ppt
bindsym $super+Shift+k resize shrink height 10 px or 10 ppt
bindsym $super+Shift+l resize grow width 10 px or 10 ppt

# change tiling layout
bindsym $super+Shift+w layout tabbed
# bindsym $super+Shift+o layout toggle split
# start main stack
bindsym $super+Shift+o  layout splitv; move left; resize grow right 20 px or 20 ppt; split v; layout stacking

# Scratchpad
## Make the currently focused window a scratchpad
bindsym $super+Shift+minus move scratchpad

# Show the first scratchpad window
bindsym $super+minus scratchpad show

bindsym $super+Shift+$alt+1 mark "sp1", move scratchpad
bindsym $super+Shift+$alt+2 mark "sp2", move scratchpad
bindsym $super+Shift+$alt+3 mark "sp3", move scratchpad
bindsym $super+Shift+$alt+4 mark "sp4", move scratchpad
bindsym $super+Shift+$alt+5 mark "sp5", move scratchpad
bindsym $super+Shift+$alt+6 mark "sp6", move scratchpad
bindsym $super+Shift+$alt+7 mark "sp7", move scratchpad
bindsym $super+Shift+$alt+8 mark "sp8", move scratchpad
bindsym $super+Shift+$alt+9 mark "sp9", move scratchpad
bindsym $super+Shift+$alt+0 mark "sp0", move scratchpad
# bindsym $super+Shift+grave mark "sp`", move scratchpad
# bindsym $super+Shift+tab mark "sp`", move scratchpad

bindsym $super+$alt+1 [con_mark="sp1"] scratchpad show, move position center, resize set 2100 1350
bindsym $super+$alt+2 [con_mark="sp2"] scratchpad show, move position center, resize set 2100 1350
bindsym $super+$alt+3 [con_mark="sp3"] scratchpad show, move position center, resize set 2100 1350
bindsym $super+$alt+4 [con_mark="sp4"] scratchpad show, move position center, resize set 2100 1350
bindsym $super+$alt+5 [con_mark="sp5"] scratchpad show, move position center, resize set 2100 1350
bindsym $super+$alt+6 [con_mark="sp6"] scratchpad show, move position center, resize set 2100 1350
bindsym $super+$alt+7 [con_mark="sp7"] scratchpad show, move position center, resize set 2100 1350
bindsym $super+$alt+8 [con_mark="sp8"] scratchpad show, move position center, resize set 2100 1350
bindsym $super+$alt+9 [con_mark="sp9"] scratchpad show, move position center, resize set 2100 1350
bindsym $super+$alt+0 [con_mark="sp0"] scratchpad show, move position center, resize set 2100 1350
bindsym $super+tab scratchpad show

