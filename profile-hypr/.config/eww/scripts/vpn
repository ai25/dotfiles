get_vpn_info() {
    # Check if mullvad command exists
    if ! command -v mullvad &> /dev/null; then
        echo '{"status": "Not Available", "country": "", "city": "", "ip": "", "relay": "", "flag": "❌"}'
        return
    fi

    # Get mullvad status
    local status_output
    status_output=$(mullvad status 2>/dev/null)

    if [[ $status_output =~ ^Connected ]]; then
        # Parse connected status
        local relay city country ip flag country_code

        # Extract relay (e.g., "ro-buh-wg-002")
        relay=$(echo "$status_output" | grep -oP 'Relay:\s+\K\S+' || echo "")

        # Extract country code from relay (first 2 characters)
        if [[ $relay =~ ^([a-z]{2})- ]]; then
            country_code="${BASH_REMATCH[1]}"
        else
            country_code=""
        fi

        # Extract visible location (e.g., "Romania, Bucharest")
        local location_line
        location_line=$(echo "$status_output" | grep "Visible location:" || echo "")

        if [[ $location_line =~ Visible\ location:\ +([^,]+),\ +([^.]+)\. ]]; then
            country="${BASH_REMATCH[1]}"
            city="${BASH_REMATCH[2]}"
        else
            country=""
            city=""
        fi

        # Extract IP address
        ip=$(echo "$status_output" | grep -oP 'IPv4:\s+\K[\d.]+' || echo "")

        # Get flag emoji
        flag=$(get_flag_emoji "$country_code")

        echo "{\"status\": \"Connected\", \"country\": \"$country\", \"city\": \"$city\", \"ip\": \"$ip\", \"relay\": \"$relay\", \"flag\": \"$flag\"}"

    elif [[ $status_output =~ ^Disconnected ]] || [[ $status_output =~ ^Blocked ]]; then
        echo '{"status": "Disconnected", "country": "", "city": "", "ip": "", "relay": "", "flag": "🔴"}'
    else
        echo '{"status": "Unknown", "country": "", "city": "", "ip": "", "relay": "", "flag": "❓"}'
    fi
}

# Entry point
if [ "$1" == "--present" ]; then
    command -v mullvad &> /dev/null && echo true || echo false
    exit 0
fi

# Default run mode
previous_status=""

# Output initial status
current_status=$(get_vpn_info)
echo "$current_status"
previous_status="$current_status"

# Monitor vpn events and poll for changes
while true; do
    sleep 3

    current_status=$(get_vpn_info)

    # Only output if status changed
    if [ "$current_status" != "$previous_status" ]; then
        echo "$current_status"
        previous_status="$current_status"
    fi
done
